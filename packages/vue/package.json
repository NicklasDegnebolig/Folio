{
  "name": "@nicklasdegnebolig/folio-vue",
  "version": "0.0.1",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@nicklasdegnebolig/folio": "workspace:*",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@nicklasdegnebolig/folio": "workspace:*",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/language-core": "^3.3.5",
    "@vue/test-utils": "^2.4.0",
    "jsdom": "^26.0.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^5.0.2",
    "vue": "^3.5.0"
  }
}
