{
  // Formatter: oxfmt via vite+ — no Prettier
  "editor.defaultFormatter": "VoidZero.vite-plus-extension-pack",
  "editor.formatOnSave": true,

  // Per-language formatter overrides
  "[vue]": {
    "editor.defaultFormatter": "VoidZero.vite-plus-extension-pack"
  },
  "[typescript]": {
    "editor.defaultFormatter": "VoidZero.vite-plus-extension-pack"
  },
  "[javascript]": {
    "editor.defaultFormatter": "VoidZero.vite-plus-extension-pack"
  },
  "[json]": {
    "editor.defaultFormatter": "VoidZero.vite-plus-extension-pack"
  },
  "[mdx]": {
    "editor.defaultFormatter": "VoidZero.vite-plus-extension-pack"
  },

  // Disable ESLint if installed — oxlint handles linting
  "eslint.enable": false,

  // oxc VSCode extension — inline lint + format feedback
  "oxc.enable": true,


  // File associations
  "files.associations": {
    "*.mdx": "mdx"
  },

  // Hide generated build artifacts from the file explorer
  "files.exclude": {
    "**/dist": true,
    "**/.vite-hooks": true
  }
}
