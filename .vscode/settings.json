{
  // Formatter: oxfmt via vite+ — no Prettier
  "editor.defaultFormatter": "VoidZero.vite-plus-extension-pack",
  "editor.formatOnSave": true,

  // Per-language formatter overrides
  "[vue]": {
    "editor.defaultFormatter": "VoidZero.vite-plus-extension-pack"
  },
  "[typescript]": {
    "editor.defaultFormatter": "VoidZero.vite-plus-extension-pack"
  },
  "[javascript]": {
    "editor.defaultFormatter": "VoidZero.vite-plus-extension-pack"
  },
  "[json]": {
    "editor.defaultFormatter": "VoidZero.vite-plus-extension-pack"
  },
  "[mdx]": {
    "editor.defaultFormatter": "VoidZero.vite-plus-extension-pack"
  },

  // Disable ESLint if installed — oxlint handles linting
  "eslint.enable": false,

  // Disable built-in JS/TS validation — oxlint handles it
  "javascript.validate.enable": false,

  // Volar — use workspace TypeScript version
  "vue.server.hybridMode": true,
  "typescript.tsdk": "node_modules/typescript/lib",

  // File associations
  "files.associations": {
    "*.mdx": "mdx"
  },

  // Hide generated build artifacts from the file explorer
  "files.exclude": {
    "**/dist": true,
    "**/.vite-hooks": true
  }
}
