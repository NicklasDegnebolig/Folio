{
  "name": "folio-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @folio/docs dev",
    "build:packages": "tsdown",
    "test": "vitest run",
    "test:core": "vitest run --project packages/core",
    "test:vue": "vitest run --project packages/vue",
    "test:watch": "vitest",
    "typecheck": "tsc --build --noEmit",
    "typecheck:core": "tsc --project packages/core/tsconfig.json --noEmit",
    "fmt": "vp fmt",
    "fmt:check": "vp fmt --check",
    "lint": "vp lint",
    "clean": "find packages apps -type d -name dist -not -path '*/node_modules/*' -exec rm -rf {} +",
    "prepare": "vp config"
  },
  "devDependencies": {
    "tsdown": "^0.22.2",
    "typescript": "^5.8.0",
    "vite-plus": "^0.1.24",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=8"
  },
  "packageManager": "pnpm@8.15.5"
}
