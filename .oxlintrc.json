{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "vue"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "rules": {
    "no-control-regex": "off"
  },
  "env": {
    "builtin": true,
    "browser": true,
    "node": true,
    "es2022": true
  },
  "ignorePatterns": ["**/dist/**", "**/node_modules/**"],
  "overrides": [
    {
      "files": ["**/*.test.ts", "**/*.spec.ts"],
      "plugins": ["vitest"],
      "categories": {
        "correctness": "error"
      }
    }
  ]
}
